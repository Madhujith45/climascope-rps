# ClimaScope Edge – Environment Variables
# Copy to .env and customise.
# Loaded automatically by python-dotenv when running main.py.

# Backend FastAPI URL (deployed on Render)
CLIMASCOPE_BACKEND_URL=https://climascope-rps.onrender.com

# Sampling interval in seconds (default: 60)
CLIMASCOPE_INTERVAL=60

# Log verbosity: DEBUG | INFO | WARNING | ERROR
CLIMASCOPE_LOG_LEVEL=INFO
