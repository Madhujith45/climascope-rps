# ClimaScope Frontend – Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.

# URL of your ClimaScope backend (Raspberry Pi IP + port)
# Examples:
#   Local dev against Pi on your LAN:
VITE_BACKEND_URL=http://192.168.1.50:8000
#   Production (Vercel) – set this in Vercel project settings, not here.
# VITE_BACKEND_URL=https://your-pi-tunnel.example.com
