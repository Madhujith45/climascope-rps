# ClimaScope Backend – Environment Variables
# Copy to .env and customise.

# Comma-separated list of frontend origins allowed by CORS
# For Vercel deployment add your production domain here.
CLIMASCOPE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# MongoDB
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=climascope

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
# Optional legacy compatibility variable:
# JWT_SECRET_KEY=change_this_to_a_long_random_secret

# Gemini AI
# Preferred variable name:
GEMINI_API_KEY=replace_with_your_gemini_key
# Optional fallback supported by code:
# GOOGLE_GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_MODEL=gemini-pro

# SMTP email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_email@gmail.com

# Optional Twilio SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_TO_PHONE=
